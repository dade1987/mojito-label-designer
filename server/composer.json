{
    "name": "mojito/label-server",
    "description": "Stampa etichette ZPL via CUPS",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "infection/infection": "^0.32",
        "laravel/pint": "^1.13",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mojito\\Label\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mojito\\Label\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --configuration phpunit.coverage.xml --coverage-text --colors=never",
        "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=512M",
        "pint": "vendor/bin/pint --test",
        "pint:fix": "vendor/bin/pint",
        "mutation": "XDEBUG_MODE=coverage vendor/bin/infection --configuration=infection.json5",
        "quality": [
            "@pint",
            "@analyse",
            "@test"
        ],
        "serve": "php -S localhost:8080 -t public public/index.php"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
